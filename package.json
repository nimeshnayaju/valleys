{
	"name": "valleys",
	"description": "A lightweight TypeScript library for validating arbitrary runtime data.",
	"version": "0.2.0",
	"license": "MIT",
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "bunchee",
		"test": "vitest run",
		"typecheck": "vitest --typecheck.only",
		"lint": "biome lint",
		"format": "biome format --write",
		"check": "biome check"
	},
	"engines": {
		"node": ">=18"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.5",
		"@types/node": "^20.19.10",
		"bunchee": "^6.9.4",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	}
}
